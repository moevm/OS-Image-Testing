[global]
directory=/tmp/testfiles
direct=1
size=17MB

[seq_write_1M]
rw=write
bs=1M

[seq_write_256k]
wait_for_previous
rw=write
bs=256k

[seq_write_64k]
wait_for_previous
rw=write
bs=64k

[rand_write_64k]
wait_for_previous
rw=randwrite
bs=64k

[rand_write_16k]
wait_for_previous
rw=randwrite
bs=16k

[rand_write_4k]
wait_for_previous
rw=randwrite
bs=4k
