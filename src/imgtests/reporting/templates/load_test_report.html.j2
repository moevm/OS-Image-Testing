{% import "test_info_header.html.j2" as test_info_header %}
{% import "chart_block.html.j2" as chart %}
{% import "stats_table.html.j2" as tables %}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Test Report</title>
  <style>
    body { font-family: Arial, Helvetica, sans-serif; margin: 24px; line-height: 1.45; }
    h1, h2, h3 { margin: 0.2em 0; }
    table { border-collapse: collapse; width: 100%; margin: 12px 0 24px 0; }
    th, td { border: 1px solid #ddd; padding: 8px; font-size: 14px; text-align: left; }
    th { background: #f7f7f7; }
    .ok { color: #116611; font-weight: 700; }
    .bad { color: #aa0000; font-weight: 700; }
    .muted { color: #666; }
    img {
      max-width: 100%;
      height: auto;
      border: 1px solid #ddd;
      padding: 6px;
      margin: 8px 0 18px 0;
    }
    code { background: #f2f2f2; padding: 2px 4px; border-radius: 3px; }
  </style>
</head>
<body>
  {{ test_info_header.render_header(header) }}

  <h2>1) Plan Timeline</h2>
  {{ tables.render_timeline_table(timeline.timeline_rows) }}

  <h2>2) Aggregated Statistics (Overall)</h2>
  <p class="muted">
    Mean, variance, quartiles and 95th percentile for collected numeric metrics
    (all stages merged).
  </p>
  {{ tables.render_stats_table(timeline.overall_rows) }}

  <h2>3) Statistics by Stage</h2>
  <p class="muted">Same stats, but computed separately for each stage.</p>
  {{ tables.render_stats_table(timeline.per_stage_rows, include_stage=true) }}

  <h2>4) Boxplot Visualizations</h2>
  {% if visualizations %}
    {% for plot in visualizations.booxplots %}
      {{ chart.render_chart(plot) }}
    {% endfor %}
  {% else %}
  <p>No plots were generated (not enough numeric samples).</p>
  {% endif %}
</body>
</html>
