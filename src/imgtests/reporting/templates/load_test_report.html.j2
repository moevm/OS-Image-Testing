{% macro render_stats_table(rows, include_stage=false) -%}
<table>
  <tr>
    {% if include_stage %}
    <th>Stage</th>
    {% endif %}
    <th>Subsystem</th>
    <th>Metric</th>
    <th>N</th>
    <th>Mean</th>
    <th>Variance</th>
    <th>Q25</th>
    <th>Q50</th>
    <th>Q75</th>
    <th>Q95</th>
    <th>Min</th>
    <th>Max</th>
  </tr>
  {% for row in rows %}
  <tr>
    {% if include_stage %}
    <td>{{ row.stage_name }}</td>
    {% endif %}
    <td>{{ row.subsystem }}</td>
    <td>{{ row.metric_name }}</td>
    <td>{{ row.count }}</td>
    <td>{{ row.mean | format_float }}</td>
    <td>{{ row.variance | format_float }}</td>
    <td>{{ row.q25 | format_float }}</td>
    <td>{{ row.q50 | format_float }}</td>
    <td>{{ row.q75 | format_float }}</td>
    <td>{{ row.q95 | format_float }}</td>
    <td>{{ row.min_v | format_float }}</td>
    <td>{{ row.max_v | format_float }}</td>
  </tr>
  {% endfor %}
</table>
{%- endmacro %}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Load Test Report</title>
  <style>
    body { font-family: Arial, Helvetica, sans-serif; margin: 24px; line-height: 1.45; }
    h1, h2, h3 { margin: 0.2em 0; }
    table { border-collapse: collapse; width: 100%; margin: 12px 0 24px 0; }
    th, td { border: 1px solid #ddd; padding: 8px; font-size: 14px; text-align: left; }
    th { background: #f7f7f7; }
    .ok { color: #116611; font-weight: 700; }
    .bad { color: #aa0000; font-weight: 700; }
    .muted { color: #666; }
    img {
      max-width: 100%;
      height: auto;
      border: 1px solid #ddd;
      padding: 6px;
      margin: 8px 0 18px 0;
    }
    code { background: #f2f2f2; padding: 2px 4px; border-radius: 3px; }
  </style>
</head>
<body>
  <h1>Load/Stress Test Report</h1>
  <p class="muted">
    Experiment ID: <b>{{ experiment_id }}</b> |
    Plan ID: <b>{{ plan_id }}</b>
  </p>
  <p class="muted">Started: {{ started_at }} | Ended: {{ ended_at }}</p>
  <p>
    Total tasks: <b>{{ total_tasks }}</b> |
    Failed: <b class="{{ 'bad' if has_failures else 'ok' }}">{{ failed_tasks }}</b>
  </p>
  <p>Plan file: <code>{{ plan_path }}</code></p>

  <h2>1) Plan Timeline</h2>
  <table>
    <tr>
      <th>Stage</th>
      <th>Pattern</th>
      <th>Planned start, sec</th>
      <th>Planned duration, sec</th>
      <th>Actual started</th>
      <th>Actual ended</th>
      <th>Actual duration, sec</th>
      <th>Tasks</th>
      <th>Failures</th>
    </tr>
    {% for row in timeline_rows %}
    <tr>
      <td>{{ row.stage_name }}</td>
      <td>{{ row.pattern }}</td>
      <td>{{ row.planned_start_sec }}</td>
      <td>{{ row.planned_duration_sec }}</td>
      <td>{{ row.actual_started }}</td>
      <td>{{ row.actual_ended }}</td>
      <td>{{ row.actual_duration_sec }}</td>
      <td>{{ row.tasks }}</td>
      <td>{{ row.failures }}</td>
    </tr>
    {% endfor %}
  </table>

  <h2>2) Aggregated Statistics (Overall)</h2>
  <p class="muted">
    Mean, variance, quartiles and 95th percentile for collected numeric metrics
    (all stages merged).
  </p>
  {{ render_stats_table(overall_rows) }}

  <h2>3) Statistics by Stage</h2>
  <p class="muted">Same stats, but computed separately for each stage.</p>
  {{ render_stats_table(per_stage_rows, include_stage=true) }}

  <h2>4) Boxplot Visualizations</h2>
  {% if plot_assets %}
    {% for plot in plot_assets %}
    <h3>{{ plot.title }}</h3>
    <img src="{{ plot.relative_path }}" alt="{{ plot.title }}">
    {% endfor %}
  {% else %}
  <p>No plots were generated (not enough numeric samples).</p>
  {% endif %}
</body>
</html>
